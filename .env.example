JWT_SECRET=replace_this_with_a_secure_random_string

# Frontend API base URL — set to your Railway backend URL in production.
# Must be set in Vercel environment variables BEFORE the first build.
VITE_API_URL=http://localhost:3001/api

# Comma-separated CORS origins allowed to call the backend.
# In production (Railway), set this to your Vercel frontend URL.
# e.g. ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173