JWT_SECRET=replace_this_with_a_secure_random_string

# VITE_API_URL — PRODUCTION ONLY.
# Set this in your Vercel dashboard (not here) pointing to your Railway backend.
# DO NOT set it for local development — the Vite proxy handles /api → localhost:3001
# and setting this bypasses the proxy, breaking HttpOnly cookie auth.
# VITE_API_URL=https://your-backend.railway.app/api

# Comma-separated CORS origins allowed to call the backend.
# Development: leave as localhost defaults.
# Production (Railway): set to your Vercel frontend URL.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
NODE_ENV=development