# ── Required secrets ──────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_secure_random_string
CSRF_SECRET=replace_this_with_a_different_secure_random_string

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Get from: Supabase → Settings → Database → Connection pooling → Session mode (port 5432)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:5432/postgres

# Set this locally if Supabase's pooler cert isn't trusted by your OS.
# Never set in production — Vercel verifies TLS fully.
# PGSSL_INSECURE=1

# ── Backup ────────────────────────────────────────────────────────────────────
# Used by scripts/backup-db.sh (local) and the GitHub Actions db-backup workflow.
# Also set this as a GitHub Actions secret: repo → Settings → Secrets → Actions → BACKUP_ENCRYPTION_KEY
# WARNING: losing this key makes all encrypted backups unrestorable.
BACKUP_ENCRYPTION_KEY=replace_with_a_strong_passphrase

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# Comma-separated origins allowed for CORS (local dev defaults)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Frontend ──────────────────────────────────────────────────────────────────
# Leave unset for local dev — frontend defaults to /api (same origin via Vite proxy).
# Set in Vercel dashboard only if you ever split frontend/backend to different domains.
# VITE_API_URL=https://your-vercel-app.vercel.app/api

# ── Email (Resend — optional, required for password reset in production) ───────
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# Public frontend URL used in password reset email links
APP_URL=http://localhost:5173
